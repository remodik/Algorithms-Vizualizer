{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "algoviz",
  "version": "0.1.0",
  "identifier": "com.remodik.algoviz",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "algoviz",
        "width": 1200,
        "height": 800,
        "additionalBrowserArgs": "--disable-features=IsolateOrigins,site-per-process --disable-site-isolation-trials --disable-features=InterestFeedContentSuggestions"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
